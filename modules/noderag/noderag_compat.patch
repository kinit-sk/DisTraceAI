         All_nodes = []
         self.config.tracker.set(len(results),'High Level Element Summary')
@@ -200,7 +204,8 @@ class SummaryGeneration:
         self.config.console.print('[bold green]Graph stored[/bold green]')
         
     def delete_community_cache(self):
-        os.remove(self.config.summary_path)
+        if os.path.exists(self.config.summary_path):   # DisTraceAI patch: may not exist
+            os.remove(self.config.summary_path)
         
     def store_high_level_elements(self):
         
diff --git a/NodeRAG/utils/token_utils.py b/NodeRAG/utils/token_utils.py
index b75015e..148dddc 100644
--- a/NodeRAG/utils/token_utils.py
+++ b/NodeRAG/utils/token_utils.py
@@ -64,7 +64,12 @@ def get_token_counter(model_name:str) -> token_counter:
     # elif 'deepseek' in model_name:
     #     return deepseek_counter(model_name)
     else:
-        raise ValueError(f"Unsupported model {model_name}")
+        # Local models (llama.cpp: gemma/qwen/llama/mistral or a .gguf path) have no
+        # tiktoken vocab. Token counts here only drive chunk sizing, so a cl100k
+        # (gpt-4o) approximation is fine. (DisTraceAI local-model patch.)
+        token = tiktoken_counter('gpt-4o')
+        token.token_limit_bound = 128000
+        return token
 
 
     
diff --git a/NodeRAG/build/component/relationship.py b/NodeRAG/build/component/relationship.py
--- a/NodeRAG/build/component/relationship.py
+++ b/NodeRAG/build/component/relationship.py
@@ -62,4 +62,11 @@
 
     @classmethod
     def from_df_row(cls,row):
-        return cls(frozen_set=row['unique_relationship'],context=row['context'],human_readable_id=row['human_readable_id'])
+        # Robust to BOTH df.itertuples() rows (namedtuples -> attribute access)
+        # and df.iterrows()/dict rows (Series/dict -> key access).
+        # load_relationship() iterates with itertuples(), whose namedtuple rows do
+        # NOT support string subscripting, which raised
+        # "TypeError: tuple indices must be integers or slices, not str".
+        g = (lambda k: row[k]) if hasattr(row, 'keys') else (lambda k: getattr(row, k))
+        return cls(frozen_set=g('unique_relationship'), context=g('context'),
+                   human_readable_id=g('human_readable_id'))

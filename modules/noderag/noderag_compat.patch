# noderag_compat.patch
# DisTraceAI compatibility fixes for stock NodeRAG (pinned commit). These are
# NOT the llama-cpp provider (dropped — the pipeline injects in-process vLLM
# clients instead). They are required behavioral fixes that let stock NodeRAG
# run on this project's data without crashing:
#   - token_utils.py: local-model tokenizers (gemma/qwen) have no tiktoken
#     vocab; fall back to a gpt-4o approximation for chunk-sizing token counts
#     instead of raising ValueError('Unsupported model ...').
#   - attribute_generation.py / relationship.py / summary_generation.py:
#     guard small/empty graphs (avoid ZeroDivisionError, log(0), and
#     betweenness_centrality(k=10) when |V| < 10). These activate only on
#     degenerate graphs and do not alter NodeRAG's algorithm on graphs large
#     enough to matter, so SpecFi replication on real corpora is unaffected.
#
# The unpatched llama-cpp provider sections (LLM.py, LLM_route.py) are
# intentionally excluded so NodeRAG's model routing stays stock (SpecFi-faithful).

diff --git a/NodeRAG/build/pipeline/attribute_generation.py b/NodeRAG/build/pipeline/attribute_generation.py
index 64ccbba..8bb2d16 100644
--- a/NodeRAG/build/pipeline/attribute_generation.py
+++ b/NodeRAG/build/pipeline/attribute_generation.py
@@ -25,10 +25,18 @@ class NodeImportance:
         self.console = console
         
     def K_core(self,k:int|None = None):
-        
+
+        # Tiny/empty graphs (e.g. a very small corpus) have no meaningful k-core.
+        # (DisTraceAI patch: avoid ZeroDivisionError / degenerate k.)
+        if self.G.number_of_nodes() == 0:
+            return
+
         if k is None:
             k = self.defult_k()
-        
+
+        if k <= 0:
+            return
+
         self.k_subgraph = nx.core.k_core(self.G,k=k)
         
         for nodes in self.k_subgraph.nodes():
@@ -36,18 +44,31 @@ class NodeImportance:
                 self.important_nodes.append(nodes)
         
     def avarege_degree(self):
-        average_degree = sum(dict(self.G.degree()).values())/self.G.number_of_nodes()
-        return average_degree
+        n = self.G.number_of_nodes()
+        if n == 0:                       # DisTraceAI patch: empty graph
+            return 0.0
+        return sum(dict(self.G.degree()).values())/n
     
     def defult_k(self):
-        k = round(np.log(self.G.number_of_nodes())*self.avarege_degree()**(1/2))
-        return k
+        n = self.G.number_of_nodes()
+        deg = self.avarege_degree()
+        if n <= 1 or deg <= 0:           # DisTraceAI patch: avoid log(0)/0-degree
+            return 0
+        return round(np.log(n)*deg**(1/2))
     
     def betweenness_centrality(self):
-        
-        self.betweenness = nx.betweenness_centrality(self.G,k=10)
+
+        # DisTraceAI patch: tolerate small/empty graphs (k must be <= |V|; avoid
+        # division by zero and math.log10(<=1)).
+        n = self.G.number_of_nodes()
+        if n == 0:
+            self.betweenness = {}
+            return
+        self.betweenness = nx.betweenness_centrality(self.G,k=min(10, n))
+        if not self.betweenness:
+            return
         average_betweenness = sum(self.betweenness.values())/len(self.betweenness)
-        scale = round(math.log10(len(self.betweenness)))
+        scale = round(math.log10(len(self.betweenness))) if len(self.betweenness) > 1 else 1
         
         for node in self.betweenness:
             if self.betweenness[node] > average_betweenness*scale:
@@ -55,6 +76,9 @@ class NodeImportance:
                     self.important_nodes.append(node)
                     
     def main(self):
+        if self.G.number_of_nodes() == 0:   # DisTraceAI patch: nothing to rank
+            self.console.print('[yellow]NodeImportance: empty graph — no important nodes[/yellow]')
+            return []
         self.K_core()
         self.console.print('[bold green]K_core done[/bold green]')
         self.betweenness_centrality()

+# ===========================================================================
+# Local llama.cpp integration (DisTraceAI patch)
+# ---------------------------------------------------------------------------
+# Drop-in replacements for the commercial OPENAI / Gemini classes that run a
+# local GGUF model in-process via llama-cpp-python. No network, no API keys.
+#
+# Config keys (model_config / embedding_config in the NodeRAG YAML):
+#   service_provider : "llama_cpp" (LLM)  |  "llama_cpp_embedding" (embeddings)
+#   model_name / embedding_model_name :
+#       either a local path to a .gguf file, OR a HuggingFace repo id
+#   gguf_file        : (repo only) filename or glob within the repo,
+#                      e.g. "*Q4_K_M*.gguf"   (default: "*.gguf")
+#   n_ctx            : context window           (default 8192)
+#   n_gpu_layers     : GPU offload layers       (default -1 = all)
+#   main_gpu         : CUDA device index        (default 0)
+#   max_tokens       : generation cap           (default 4096)
+#   temperature      : sampling temperature     (default 0.0)
+# ===========================================================================
+import asyncio as _asyncio
+import threading as _threading
+
+_LlamaCpp = LazyImport("llama_cpp", "Llama")
+
+
+def _load_llama_model(model_name: str, config: ModelConfig, *, embedding: bool):
+    """Construct a llama_cpp.Llama from a local .gguf path or a HF repo id."""
+    Llama = _LlamaCpp
+    common = dict(
+        n_ctx=int(config.get("n_ctx", 8192)),
+        n_gpu_layers=int(config.get("n_gpu_layers", -1)),
+        main_gpu=int(config.get("main_gpu", 0)),
+        embedding=embedding,
+        verbose=bool(config.get("verbose", False)),
+    )
+    if model_name and model_name.endswith(".gguf") and os.path.exists(model_name):
+        return Llama(model_path=model_name, **common)
+    # otherwise treat model_name as a HuggingFace repo id (filename may be a glob)
+    return Llama.from_pretrained(
+        repo_id=model_name,
+        filename=config.get("gguf_file", "*.gguf"),
+        **common,
+    )
+
+
+class Llama_cpp(LLM):
+    """Local chat-completion model (llama.cpp). Mirrors the OPENAI class API."""
+
+    def __init__(self, model_name: str, api_keys: str | None,
+                 Config: ModelConfig | None = None) -> None:
+        super().__init__(model_name, api_keys, Config)
+        Config = Config or {}
+        self.config = self.extract_config(Config)
+        self.llm = _load_llama_model(model_name, Config, embedding=False)
+        self._lock = _threading.Lock()        # llama.cpp context is not concurrency-safe
+
+    def extract_config(self, config: ModelConfig) -> ModelConfig:
+        return {
+            "max_tokens": config.get("max_tokens", 4096),
+            "temperature": config.get("temperature", 0.0),
+        }
+
+    def messages(self, input: LLM_message) -> OpenAI_message:
+        messages = []
+        if input.get("system_prompt"):
+            messages.append({"role": "system", "content": input["system_prompt"]})
+        messages.append({"role": "user", "content": input["query"]})
+        return messages
+
+    def _completion(self, messages, response_format=None):
+        params = {
+            "messages": messages,
+            "max_tokens": self.config["max_tokens"],
+            "temperature": self.config["temperature"],
+        }
+        if response_format is not None:
+            # NodeRAG passes a pydantic model; constrain generation to its schema
+            schema = response_format.model_json_schema() \
+                if hasattr(response_format, "model_json_schema") else response_format
+            params["response_format"] = {"type": "json_object", "schema": schema}
+        with self._lock:
+            response = self.llm.create_chat_completion(**params)
+        content = response["choices"][0]["message"]["content"].strip()
+        return json.loads(content) if response_format is not None else content
+
+    @error_handler
+    def API_client(self, input: LLM_message) -> LLMOutput:
+        return self._completion(self.messages(input), input.get("response_format"))
+
+    @error_handler_async
+    async def API_client_async(self, input: LLM_message) -> LLMOutput:
+        # llama.cpp is blocking; run it off the event loop (the lock serialises calls)
+        return await _asyncio.to_thread(
+            self._completion, self.messages(input), input.get("response_format"))
+
+    def stream_chat(self, input: LLM_message):
+        messages = self.messages(input)
+        with self._lock:
+            for chunk in self.llm.create_chat_completion(
+                    messages=messages, temperature=self.config["temperature"],
+                    max_tokens=self.config["max_tokens"], stream=True):
+                delta = chunk["choices"][0].get("delta", {})
+                if delta.get("content"):
+                    yield delta["content"]
+
+
+class Llama_cpp_Embedding(LLM):
+    """Local embedding model (llama.cpp, embedding=True). Mirrors OpenAI_Embedding."""
+
+    def __init__(self, model_name: str, api_keys: str | None,
+                 Config: ModelConfig | None = None) -> None:
+        super().__init__(model_name, api_keys, Config)
+        Config = Config or {}
+        self.llm = _load_llama_model(model_name, Config, embedding=True)
+        self._lock = _threading.Lock()
+
+    @staticmethod
+    def _as_list(input) -> list:
+        if isinstance(input, dict) and "input" in input:
+            input = input["input"]
+        if isinstance(input, str):
+            return [input]
+        return list(input)
+
+    def _embed(self, input) -> Embedding_output:
+        texts = self._as_list(input)
+        with self._lock:
+            response = self.llm.create_embedding(texts)
+        return [row["embedding"] for row in response["data"]]
+
+    @error_handler
+    def API_client(self, input: Embedding_message) -> Embedding_output:
+        return self._embed(input)
+
+    @error_handler_async
+    async def API_client_async(self, input: Embedding_message) -> Embedding_output:
+        return await _asyncio.to_thread(self._embed, input)
